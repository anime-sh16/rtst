<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Output image (last stylized frame) -->
        <ImageView
            android:id="@+id/imageViewBenchOutput"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:scaleType="fitCenter"
            android:contentDescription="Benchmark output" />

        <!-- Config section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Model / Backend"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <Spinner
            android:id="@+id/spinnerModel"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- Warmup + Measure iters side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Warmup iters"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <EditText
                    android:id="@+id/editWarmup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="5" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Measure iters"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <EditText
                    android:id="@+id/editMeasureIters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="20" />
            </LinearLayout>
        </LinearLayout>

        <!-- Progress bar (visible during benchmark run) -->
        <ProgressBar
            android:id="@+id/progressBarBench"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <!-- Run button -->
        <Button
            android:id="@+id/buttonRunBenchmark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Run Benchmark" />

        <!-- Results display -->
        <TextView
            android:id="@+id/textViewResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:text="Tap 'Run Benchmark' to start." />

    </LinearLayout>

</ScrollView>
