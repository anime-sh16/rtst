<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CameraX preview (background — shows raw camera feed) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Stylized output overlay (drawn on top of preview) -->
    <ImageView
        android:id="@+id/stylizedOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- Top bar: model selector + toggle between raw/stylized view -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="#80000000">

        <Spinner
            android:id="@+id/spinnerModel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleView"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Raw"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <!-- FPS / latency indicator -->
    <TextView
        android:id="@+id/textLatency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:padding="12dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:background="#80000000"
        android:text="-- ms" />

</FrameLayout>
